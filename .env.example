# ─────────────────────────────────────────────────────────
# vox2d configuration
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────

# LLM provider: "openrouter" or "ollama"
LLM_PROVIDER=openrouter

# Model identifier (depends on provider). Default uses an OpenRouter :free
# model — no credits required.
#
# OpenRouter :free models share a rate limit:
#   - ~20 requests/minute (across all :free models)
#   - 50 requests/day on a fresh account
#   - 1000 requests/day if you've ever bought >= $10 in credits (one-time unlock)
# See: https://openrouter.ai/docs/api/reference/limits
# To unlock more headroom: https://openrouter.ai/credits
#
# OpenRouter :free picks (good for Mermaid):
#   openai/gpt-oss-120b:free                  (default — 117B MoE, strong reasoning)
#   qwen/qwen-2.5-coder-32b-instruct:free     (coder-specialized, Mermaid-friendly)
#   tencent/hy3:free                          (295B MoE, agentic/coding)
#
# Paid OpenRouter (needs credits, no daily cap):
#   openai/gpt-4o-mini, anthropic/claude-3.5-sonnet
#
# Ollama (self-hosted or Cloud):
#   llama3.1, mistral, qwen2.5-coder
#
# Full free list: https://openrouter.ai/collections/free-models
LLM_MODEL=openai/gpt-oss-120b:free

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama Cloud (or self-hosted)
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=

# Diagram render URL (Mermaid live, PlantUML, or self-hosted)
# Defaults to the official mermaid.ink image-rendering service
RENDER_URL=https://mermaid.ink

# Speech-to-text provider: "webspeech" (browser), "whisper" (server), "none"
STT_PROVIDER=webspeech

# Max auto-retry attempts when the generated Mermaid fails to render
MAX_RETRY_ATTEMPTS=3

# Optional: enable LLM request/response logging
DEBUG_LLM=false
